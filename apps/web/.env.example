# Sanity — https://sanity.io/manage → Project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_API_VERSION=2025-08-29
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# Sanity API tokens — https://sanity.io/manage → Project → API → Tokens
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Sanity webhook revalidation secret (optional — set to enable on-demand revalidation)
# Generate with: openssl rand -hex 32
# SANITY_REVALIDATE_SECRET=

# Shopify Storefront API — https://admin.shopify.com → Settings → Apps → Develop apps
# Your store's .myshopify.com domain (e.g. my-store.myshopify.com)
SHOPIFY_STORE_DOMAIN=
# Storefront API access token (requires unauthenticated_read_* scopes)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# Shopify API version (defaults to 2025-01 if not set)
SHOPIFY_API_VERSION=2025-01

# Sentry error tracking (optional — leave empty to disable)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=

# Google Tag Manager (optional — leave empty to disable)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXX
